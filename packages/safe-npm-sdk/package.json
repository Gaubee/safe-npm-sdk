{
  "name": "safe-npm-sdk",
  "version": "0.1.0",
  "description": "Modern TypeScript SDK for the npm registry API — ESM + fetch + zod",
  "keywords": [
    "api",
    "npm",
    "oidc",
    "publish",
    "registry",
    "sdk",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "prepublishOnly": "vp run typecheck && vp run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
